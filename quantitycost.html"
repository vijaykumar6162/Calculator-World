<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quantity Cost Calculator</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:linear-gradient(135deg,#0f172a,#1e293b);
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:20px;
}

.container{
width:100%;
max-width:700px;
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 15px 40px rgba(0,0,0,.3);
}

.icon{
text-align:center;
font-size:60px;
margin-bottom:10px;
}

h1{
text-align:center;
color:#2563eb;
margin-bottom:20px;
}

.input-group{
margin-bottom:15px;
}

label{
display:block;
font-weight:600;
margin-bottom:6px;
}

input,select{
width:100%;
padding:12px;
border:2px solid #ddd;
border-radius:10px;
font-size:16px;
}

button{
width:100%;
padding:14px;
background:#2563eb;
color:white;
border:none;
border-radius:10px;
font-size:18px;
cursor:pointer;
}

button:hover{
background:#1d4ed8;
}

.result{
display:none;
margin-top:20px;
background:#f8fafc;
padding:20px;
border-radius:15px;
}

.card{
background:white;
padding:12px;
margin:10px 0;
border-left:5px solid #2563eb;
border-radius:8px;
}

.highlight{
color:#16a34a;
font-weight:bold;
}
</style>
</head>
<body>

<div class="container">

<div class="icon">🛒</div>

<h1>Quantity Cost Calculator</h1>

<div class="input-group">
<label>Item Name</label>
<input type="text" id="itemName"
placeholder="Example: Rice, Wire, Apple">
</div>

<div class="input-group">
<label>Price Per Unit (₹)</label>
<input type="number" id="price"
placeholder="Enter Price">
</div>

<div class="input-group">
<label>Quantity</label>
<input type="number" id="quantity"
step="0.001"
placeholder="Enter Quantity">
</div>

<div class="input-group">
<label>Unit</label>
<select id="unit">
<option>Kg</option>
<option>Gram</option>
<option>Liter</option>
<option>Meter</option>
<option>Piece</option>
<option>Box</option>
<option>Packet</option>
</select>
</div>

<button onclick="calculateCost()">
Calculate Cost
</button>

<div class="result" id="result">

<div class="card">
📦 Item:
<span class="highlight" id="item"></span>
</div>

<div class="card">
📏 Quantity:
<span class="highlight" id="qty"></span>
</div>

<div class="card">
💰 Price Per Unit:
<span class="highlight" id="unitPrice"></span>
</div>

<div class="card">
🧾 Total Cost:
<span class="highlight" id="totalCost"></span>
</div>

</div>

</div>

<script>

function calculateCost(){

let item =
document.getElementById("itemName").value;

let price =
parseFloat(document.getElementById("price").value);

let quantity =
parseFloat(document.getElementById("quantity").value);

let unit =
document.getElementById("unit").value;

if(isNaN(price) || isNaN(quantity)){
alert("Please enter valid values");
return;
}

let total = price * quantity;

document.getElementById("item").innerHTML =
item || "Product";

document.getElementById("qty").innerHTML =
quantity + " " + unit;

document.getElementById("unitPrice").innerHTML =
"₹" + price.toLocaleString('en-IN');

document.getElementById("totalCost").innerHTML =
"₹" + total.toLocaleString('en-IN',{
maximumFractionDigits:2
});

document.getElementById("result").style.display =
"block";

}

</script>

</body>
</html>
